flowchart TD
%% Clients are ignored for now

%% Core layers
    GRPC["gRPC Service (Tasks + Auth)"]
    MANAGER["Manager Layer\n(TasksManager, AuthManager)"]
    REPO["Repositories\n(TasksRepository, UserRepository)"]
    MEMENTO["Memento\n(Task Logs)"]
    SYSLOG["Syslog / Logging"]
    FLYWAY["Flyway / DB Migrations"]
    CONFIG["Config / Env"]
    SCHEDULER["Scheduler Helper (next occurrence logic)"]
%% Dependencies
    GRPC --> MANAGER
    MANAGER --> REPO
    MANAGER --> MEMENTO
    MANAGER --> SCHEDULER
    REPO --> FLYWAY
    GRPC --> SYSLOG
    MANAGER --> SYSLOG
    REPO --> SYSLOG
    MEMENTO --> SYSLOG
    GRPC --> CONFIG
    MANAGER --> CONFIG
    REPO --> CONFIG
    MEMENTO --> CONFIG
    SYSLOG --> CONFIG
